let scale = 0;
let offset = 0;
let textsize = 0;
let snapto = 0.5;

// Verwijder de enkele globale canvas variabele en maak er twee
let canvas1;
let canvas2;

let numPositions = 8;
let inAnimation;
let Transparantie = 100;
let bw = 0;
let bh = 0;
let rectHeight;
let rectWidth;
let personScale = 1;  // Grootte van personen op het grid (0.7 = 70% van normale grootte)
let noclear = false;

function next() {
    inAnimation = false;
    if (current < BILDER.length - 1) {
        current++;
        refresh();
    }
}

function prev() {
    inAnimation = false;
    if (current > 0) {
        current--;
        refresh();
    }
}

function resizeCanvases() {
    // Reset offset en scale om opnieuw te berekenen
    offset = 0;
    scale = 0;
    bw = 0;
    bh = 0;

    // Deel de innerWidth door 2 zodat er twee canvassen naast elkaar passen
    while (bw * 1.1 < (innerWidth / 2) && bh * 1.3 < innerHeight) {
        offset++;
        scale = offset * 2;
        bw = scale * (2 * FLOORSIZE + 1) + 1 + 2 * offset;
        bh = scale * (2 * FLOORSIZE + 1) + 1 + 2 * offset;
    }
    textsize = Math.ceil(offset / 1.2);
    rectHeight = offset/1.0;
    rectWidth = offset/1.0;

    // Stel afmetingen voor beide canvassen in
    canvas1.setAttribute("height", "" + bh);
    canvas1.setAttribute("width", "" + bw);
    canvas2.setAttribute("height", "" + bh);
    canvas2.setAttribute("width", "" + bw);

    refresh();
}

window.onload = function () {
    document.querySelector(':root').style.setProperty('--teamcolor', COLOR);

    canvas1 = document.getElementById('halle');
    canvas2 = document.getElementById('halle2');


    // Snelheid Slider Logica
    let speedSlider = document.getElementById('speedSlider');
    if (speedSlider) {
        speedSlider.addEventListener('input', function() {
            // Overschrijf de globale speed variabele uit index.js
            speed = parseInt(this.value); 
        });
    }

    // Transparantie Slider Logica
    let transSlider = document.getElementById('transparencySlider');
    if (transSlider) {
        transSlider.addEventListener('input', function() {
            Transparantie = this.value;
            canvas2.style.opacity = Transparantie / 100;
        });
    }
	
	
    // Listeners nu koppelen aan canvas1
    canvas1.addEventListener('click', function (event) {
        onclick(gridToCoord(event.clientX - canvas1.offsetLeft), gridToCoord(event.clientY - canvas1.offsetTop))
    });
    canvas1.addEventListener('mousemove', function (event) {
        onmove(gridToCoord(event.clientX - canvas1.offsetLeft), gridToCoord(event.clientY - canvas1.offsetTop))
    });
    
    window.addEventListener('keydown', this.onkey, false);

    // Canvas responsief maken: aanpassen bij schermgrootte wijziging
    window.addEventListener('resize', resizeCanvases);

    // Initiële groottebepaling
    resizeCanvases();
};

function drawFloor(context) {
    // Gebruik de actuele breedte en hoogte van de context i.p.v. het globale canvas object
    context.clearRect(0, 0, context.canvas.width, context.canvas.height);
    context.beginPath();

    context.font = textsize + "px Cambria";
    context.textAlign = "left";
	//context.textAlign = "center";
    context.textBaseline = "middle";
    context.fillStyle = "#000000";

    for (var i = -FLOORSIZE; i <= FLOORSIZE; i += 1) {
        context.fillText(Math.abs(i), coordToGrid(i), offset / 2);
        context.fillText(Math.abs(i), coordToGrid(i), bh - offset / 2);

        context.moveTo(0.5 + coordToGrid(i), 0 + offset);
        context.lineTo(0.5 + coordToGrid(i), bh - offset);
        context.fillText(Math.abs(i), offset / 2, coordToGrid(i));
        context.fillText(Math.abs(i), bw - offset / 2, coordToGrid(i));

        context.moveTo(0 + offset, 0.5 + coordToGrid(i));
        context.lineTo(bw - offset, 0.5 + coordToGrid(i));
    }

    context.strokeStyle = "black";
    context.stroke();

    context.beginPath();
    context.moveTo(0.5 + coordToGrid(0), 0 + offset);
    context.lineTo(0.5 + coordToGrid(0), bh - offset);

    context.moveTo(0 + offset, 0.5 + coordToGrid(0));
    context.lineTo(bw - offset, 0.5 + coordToGrid(0));

    context.strokeStyle = "red";
    context.stroke();
}

// drawBoard is nu 'doelbewust': het neemt het canvas en de juiste array met punten aan
function drawBoard(targetCanvas, targetPoints) {
    if (!targetCanvas) return;
    const context = targetCanvas.getContext("2d");
    drawFloor(context);

    if (targetPoints) {
        for (let pointsKey = 0; pointsKey < numPositions; pointsKey++) {
            if (targetPoints[pointsKey]) {
                drawPoint(context, targetPoints[pointsKey]);
            }
        }
    }
}


function drawPoint(context, point) {
    if(point.dx !== undefined && point.dy !== undefined && (point.dx !== point.x || point.dy !== point.y)){
        var rectX = coordToGrid(point.dx);
        var rectY = coordToGrid(point.dy);
        drawMan(context, point)
    } else {
        var rectX = coordToGrid(point.x);
        var rectY = coordToGrid(point.y);
    }

    context.fillStyle = POINT_COLORS[point.p - 1];

    context.beginPath();
    context.moveTo(rectX - rectWidth * positionScale, rectY);
    context.lineTo(rectX, rectY - rectHeight * positionScale);
    context.lineTo(rectX + rectWidth * positionScale, rectY);
    context.lineTo(rectX, rectY + rectHeight * positionScale);
    context.fill();

    //context.fillRect(rectX - (rectWidth / 2), rectY - (rectHeight / 2), rectWidth, rectHeight);
    context.font = textsize + "px Cambria";
    context.textAlign = "center";
    context.textBaseline = "middle";
    context.fillStyle = "white";
    const label = (typeof POSITION_LABELS !== 'undefined' && POSITION_LABELS[point.p - 1] !== undefined)
        ? POSITION_LABELS[point.p - 1]
        : point.p;

    context.fillText(label, rectX, rectY);
}

function drawMan(context, point) {
    var rectX = coordToGrid(point.x);
    var rectY = coordToGrid(point.y);
    context.fillStyle = "Black";

    context.beginPath();
    context.moveTo(rectX - rectWidth * personScale, rectY);
    context.lineTo(rectX, rectY - rectHeight * personScale);
    context.lineTo(rectX + rectWidth * personScale, rectY);
    context.lineTo(rectX, rectY + rectHeight * personScale);
    context.fill();

    //context.fillRect(rectX - (rectWidth / 2), rectY - (rectHeight / 2), rectWidth, rectHeight);
    context.font = (textsize * personScale) + "px Cambria";
    context.textAlign = "center";
    context.textBaseline = "middle";
    context.fillStyle = "white";
    const label = (typeof POSITION_LABELS !== 'undefined' && POSITION_LABELS[point.p - 1] !== undefined)
        ? POSITION_LABELS[point.p - 1]
        : point.p;

    context.fillText(label, rectX, rectY);

}


function gridToCoord(g) {
    return (g - 2 * offset - 0.5) / scale - FLOORSIZE;
}

function coordToGrid(c) {
    return (c + FLOORSIZE) * scale + 2 * offset + 0.5;
}

function snap(p) {
    return Math.round(p / snapto) * snapto;
}

